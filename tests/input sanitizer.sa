// Simple Input Sanitizer
function sanitizeString(input) {
  return input
    .trim()
    .replace(/[<>]/g, '') // Remove HTML tags
    .replace(/javascript:/gi, '') // Remove javascript protocol
    .replace(/on\w+=/gi, ''); // Remove event handlers
}

function sanitizeHTML(input) {
  const div = document.createElement('div');
  div.textContent = input;
  return div.innerHTML;
}

function sanitizeNumber(input) {
  const clean = input.replace(/[^0-9.-]/g, '');
  return parseFloat(clean) || 0;
}

function sanitizeEmail(input) {
  return input.toLowerCase().trim().replace(/[^a-z0-9@._-]/g, '');
}

function sanitizePhone(input) {
  return input.replace(/\D/g, ''); // Keep only digits
}

function sanitizeURL(input) {
  // Basic URL sanitization
  if (!input.startsWith('http://') && !input.startsWith('https://')) {
    return 'https://' + input;
  }
  return input;
}

function sanitizeFilename(input) {
  return input
    .trim()
    .replace(/[<>:"/\\|?*]/g, '') // Remove invalid filename characters
    .substring(0, 255); // Limit length
}

// Usage examples
const inputs = [
  '<script>alert("xss")</script>',
  'javascript:alert("hack")',
  '  Hello World  ',
  'abc123def',
  'user@example.com',
  '(123) 456-7890',
  'google.com',
  'invalid/file:name.txt'
];

console.log('String sanitization:');
console.log(sanitizeString(inputs[0]));
console.log(sanitizeString(inputs[1]));
console.log(sanitizeString(inputs[2]));

console.log('\nOther sanitizations:');
console.log('Number:', sanitizeNumber(inputs[3]));
console.log('Email:', sanitizeEmail(inputs[4]));
console.log('Phone:', sanitizePhone(inputs[5]));
console.log('URL:', sanitizeURL(inputs[6]));
console.log('Filename:', sanitizeFilename(inputs[7]));

console.log('\nInput sanitizer ready!');
