// Simple URL Helper
function getQueryParams() {
  const params = {};
  const queryString = window.location.search.substring(1);
  const pairs = queryString.split('&');
  
  for (const pair of pairs) {
    const [key, value] = pair.split('=');
    params[decodeURIComponent(key)] = decodeURIComponent(value || '');
  }
  
  return params;
}

function buildURL(base, params) {
  const url = new URL(base);
  
  Object.keys(params).forEach(key => {
    url.searchParams.set(key, params[key]);
  });
  
  return url.toString();
}

function getURLSegment(index) {
  const path = window.location.pathname;
  const segments = path.split('/').filter(segment => segment);
  return segments[index] || null;
}

function isValidURL(string) {
  try {
    new URL(string);
    return true;
  } catch (_) {
    return false;
  }
}

// Usage examples
const params = getQueryParams();
console.log('Query params:', params);

const newURL = buildURL('https://example.com/api', {
  search: 'javascript',
  page: 1,
  limit: 10
});

console.log('Built URL:', newURL);

const firstSegment = getURLSegment(0);
console.log('First URL segment:', firstSegment);

console.log('Is valid URL:', isValidURL('https://google.com'));
console.log('Is valid URL:', isValidURL('not-a-url'));

console.log('URL helper ready!');
