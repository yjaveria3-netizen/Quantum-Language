# Hangman Game
# Classic word guessing game

import random

class HangmanGame:
    def __init__(self):
        self.word_list = [
            "python", "programming", "computer", "algorithm", "function",
            "variable", "loop", "condition", "array", "string",
            "class", "object", "method", "inheritance", "polymorphism",
            "database", "network", "server", "client", "protocol",
            "encryption", "security", "authentication", "authorization",
            "javascript", "html", "css", "react", "angular",
            "science", "mathematics", "physics", "chemistry", "biology",
            "geography", "history", "literature", "philosophy", "psychology"
        ]
        
        self.difficulties = {
            'easy': {'words': 6, 'guesses': 8},
            'medium': {'words': 8, 'guesses': 6},
            'hard': {'words': 10, 'guesses': 4}
        }
    
    def select_word(self, difficulty='medium'):
        """Select a random word based on difficulty"""
        min_length = self.difficulties[difficulty]['words']
        suitable_words = [word for word in self.word_list if len(word) >= min_length]
        return random.choice(suitable_words)
    
    def display_hangman(self, wrong_guesses):
        """Display hangman figure based on wrong guesses"""
        stages = [
            """
               -----
               |   |
                   |
                   |
                   |
                   |
             ---------
            """,
            """
               -----
               |   |
               O   |
                   |
                   |
                   |
             ---------
            """,
            """
               -----
               |   |
               O   |
               |   |
                   |
                   |
             ---------
            """,
            """
               -----
               |   |
               O   |
              /|   |
                   |
                   |
             ---------
            """,
            """
               -----
               |   |
               O   |
              /|\\  |
                   |
                   |
             ---------
            """,
            """
               -----
               |   |
               O   |
              /|\\  |
              /    |
                   |
             ---------
            """,
            """
               -----
               |   |
               O   |
              /|\\  |
              / \\  |
                   |
             ---------
            """
        ]
        
        stage_index = min(wrong_guesses, len(stages) - 1)
        print(stages[stage_index])
    
    def display_word_state(self, word, guessed_letters):
        """Display the current state of the word with guessed letters"""
        display = ""
        for letter in word:
            if letter in guessed_letters:
                display += letter + " "
            else:
                display += "_ "
        print(display.strip())
    
    def get_guess(self, guessed_letters):
        """Get a valid guess from the player"""
        while True:
            guess = input("Enter a letter: ").lower().strip()
            
            if len(guess) != 1:
                print("Please enter a single letter")
            elif not guess.isalpha():
                print("Please enter a letter")
            elif guess in guessed_letters:
                print("You already guessed that letter")
            else:
                return guess
    
    def calculate_score(self, word, wrong_guesses, max_guesses):
        """Calculate score based on performance"""
        if wrong_guesses >= max_guesses:
            return 0  # Lost the game
        
        # Base score for winning
        base_score = 100
        
        # Penalty for wrong guesses
        penalty = wrong_guesses * 10
        
        # Bonus for word difficulty
        difficulty_bonus = len(word) * 2
        
        total_score = max(0, base_score - penalty + difficulty_bonus)
        return total_score
    
    def play_game(self):
        """Play a single game of hangman"""
        print("\nWelcome to Hangman!")
        print("=" * 25)
        
        # Select difficulty
        print("\nSelect Difficulty:")
        print("1. Easy (8 guesses)")
        print("2. Medium (6 guesses)")
        print("3. Hard (4 guesses)")
        
        while True:
            try:
                diff_choice = input("Enter difficulty (1-3): ")
                if diff_choice == '1':
                    difficulty = 'easy'
                    break
                elif diff_choice == '2':
                    difficulty = 'medium'
                    break
                elif diff_choice == '3':
                    difficulty = 'hard'
                    break
                else:
                    print("Please enter 1, 2, or 3")
            except ValueError:
                print("Please enter a valid number")
        
        # Initialize game
        word = self.select_word(difficulty)
        max_guesses = self.difficulties[difficulty]['guesses']
        guessed_letters = set()
        wrong_guesses = 0
        
        print(f"\nDifficulty: {difficulty.capitalize()}")
        print(f"You have {max_guesses} guesses")
        print(f"The word has {len(word)} letters")
        
        # Game loop
        while wrong_guesses < max_guesses:
            print(f"\nGuesses remaining: {max_guesses - wrong_guesses}")
            self.display_hangman(wrong_guesses)
            self.display_word_state(word, guessed_letters)
            
            # Show guessed letters
            if guessed_letters:
                print(f"Guessed letters: {', '.join(sorted(guessed_letters))}")
            
            # Check if player won
            if all(letter in guessed_letters for letter in word):
                score = self.calculate_score(word, wrong_guesses, max_guesses)
                print(f"\n🎉 Congratulations! You guessed the word: {word}")
                print(f"Score: {score}")
                return True
            
            # Get player guess
            guess = self.get_guess(guessed_letters)
            guessed_letters.add(guess)
            
            # Check guess
            if guess in word:
                print(f"✓ Good guess! '{guess}' is in the word")
            else:
                print(f"✗ Wrong guess! '{guess}' is not in the word")
                wrong_guesses += 1
        
        # Player lost
        self.display_hangman(wrong_guesses)
        print(f"\n💀 Game Over! The word was: {word}")
        print("Score: 0")
        return False

def hangman_tournament():
    """Multi-round tournament mode"""
    print("\nHangman Tournament")
    print("=" * 25)
    
    try:
        rounds = int(input("Enter number of rounds (1-10): "))
        rounds = max(1, min(10, rounds))
    except ValueError:
        rounds = 3
    
    game = HangmanGame()
    scores = []
    wins = 0
    
    for round_num in range(1, rounds + 1):
        print(f"\n{'='*40}")
        print(f"Round {round_num} of {rounds}")
        print(f"{'='*40}")
        
        won = game.play_game()
        
        if won:
            wins += 1
        
        if round_num < rounds:
            input("Press Enter to continue to next round...")
    
    # Show tournament results
    print(f"\n{'='*40}")
    print("TOURNAMENT RESULTS")
    print(f"{'='*40}")
    print(f"Rounds played: {rounds}")
    print(f"Wins: {wins}")
    print(f"Losses: {rounds - wins}")
    print(f"Win rate: {(wins/rounds)*100:.1f}%")
    
    if wins == rounds:
        print("🏆 Perfect tournament! You won all rounds!")
    elif wins >= rounds * 0.7:
        print("🌟 Excellent performance!")
    elif wins >= rounds * 0.5:
        print("👍 Good job!")
    else:
        print("📚 Keep practicing!")

def word_practice_mode():
    """Practice mode with hints"""
    print("\nWord Practice Mode")
    print("=" * 25)
    
    game = HangmanGame()
    word = random.choice(game.word_list)
    
    print(f"Practice word: {len(word)} letters")
    print("Type 'hint' for a hint (costs 2 points)")
    
    guessed_letters = set()
    wrong_guesses = 0
    max_guesses = 8
    hints_used = 0
    
    while wrong_guesses < max_guesses:
        print(f"\nGuesses remaining: {max_guesses - wrong_guesses}")
        game.display_hangman(wrong_guesses)
        game.display_word_state(word, guessed_letters)
        
        if all(letter in guessed_letters for letter in word):
            print(f"\n🎉 Great job! The word was: {word}")
            return
        
        # Get input
        user_input = input("Enter a letter (or 'hint'): ").lower().strip()
        
        if user_input == 'hint':
            if hints_used < 2:
                # Find an unguessed letter
                unguessed = [letter for letter in word if letter not in guessed_letters]
                if unguessed:
                    hint_letter = random.choice(unguessed)
                    print(f"💡 Hint: The letter '{hint_letter}' is in the word")
                    hints_used += 1
                else:
                    print("No hints available")
            else:
                print("You've used all available hints")
            continue
        
        # Validate input
        if len(user_input) != 1 or not user_input.isalpha():
            print("Please enter a single letter")
            continue
        
        if user_input in guessed_letters:
            print("You already guessed that letter")
            continue
        
        guessed_letters.add(user_input)
        
        if user_input in word:
            print(f"✓ Good guess! '{user_input}' is in the word")
        else:
            print(f"✗ Wrong guess! '{user_input}' is not in the word")
            wrong_guesses += 1
    
    print(f"\n💀 Practice over! The word was: {word}")

def main_menu():
    """Main menu for hangman game"""
    print("HANGMAN GAME")
    print("=" * 15)
    
    game = HangmanGame()
    
    while True:
        print("\nMain Menu:")
        print("1. Single Game")
        print("2. Tournament Mode")
        print("3. Practice Mode")
        print("4. Instructions")
        print("5. Exit")
        
        choice = input("Enter your choice (1-5): ")
        
        if choice == '1':
            game.play_game()
        
        elif choice == '2':
            hangman_tournament()
        
        elif choice == '3':
            word_practice_mode()
        
        elif choice == '4':
            print("\nHOW TO PLAY HANGMAN:")
            print("-" * 30)
            print("1. The computer selects a random word")
            print("2. You guess letters one at a time")
            print("3. Correct guesses reveal letters in the word")
            print("4. Wrong guesses add parts to the hangman")
            print("5. Win by guessing the word before the hangman is complete")
            print("6. Different difficulties have different word lengths and guess limits")
            print("\nSCORING:")
            print("- Base score: 100 points")
            print("- Penalty: -10 points per wrong guess")
            print("- Bonus: +2 points per letter in the word")
        
        elif choice == '5':
            print("Thanks for playing Hangman!")
            break
        
        else:
            print("Invalid choice. Please try again.")

# Run the hangman game
main_menu()
