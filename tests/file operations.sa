print("\n=== Cleanup ===");
print("Cleaning up test files...");

# Note: In a real implementation, you would have file deletion capability
# For this example, we'll just list what would be cleaned up
let files_to_cleanup = [filename, copy_filename, csv_filename, json_filename, "application.log"];
for (let i = 0; i < len(test_files); i++) {
    files_to_cleanup.push(test_files[i]);
}

print("Files that would be cleaned up:");
for (let i = 0; i < len(files_to_cleanup); i++) {
    print("  ", files_to_cleanup[i]);
}

print("\nFile operations examples completed!");
