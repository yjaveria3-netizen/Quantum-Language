# merge_sort.sa - Merge Sort Algorithm Implementation
# C-style merge sort implementation in Quantum Language

function merge(arr, left, mid, right) {
    let n1 = mid - left + 1;
    let n2 = right - mid;
    
    # Create temporary arrays
    let L = [];
    let R = [];
    
    # Copy data to temporary arrays
    for (let i = 0; i < n1; i++) {
        L.push(arr[left + i]);
    }
    for (let j = 0; j < n2; j++) {
        R.push(arr[mid + 1 + j]);
    }
    
    # Merge the temporary arrays back into arr[left..right]
    let i = 0;  # Initial index of first subarray
    let j = 0;  # Initial index of second subarray
    let k = left;  # Initial index of merged subarray
    
    while (i < n1 && j < n2) {
        if (L[i] <= R[j]) {
            arr[k] = L[i];
            i++;
        } else {
            arr[k] = R[j];
            j++;
        }
        k++;
    }
    
    # Copy remaining elements of L[] if any
    while (i < n1) {
        arr[k] = L[i];
        i++;
        k++;
    }
    
    # Copy remaining elements of R[] if any
    while (j < n2) {
        arr[k] = R[j];
        j++;
        k++;
    }
}

function merge_sort(arr, left, right) {
    if (left < right) {
        # Same as (left+right)/2, but avoids overflow for large left and right
        let mid = left + (right - left) / 2;
        
        # Sort first and second halves
        merge_sort(arr, left, mid);
        merge_sort(arr, mid + 1, right);
        
        merge(arr, left, mid, right);
    }
}

function merge_sort_wrapper(arr) {
    merge_sort(arr, 0, len(arr) - 1);
    return arr;
}

# Test the merge sort implementation
let test_array = [12, 11, 13, 5, 6, 7, 2, 9, 15, 1, 8];
print("Original array:", test_array);

let sorted_array = merge_sort_wrapper(test_array.copy());
print("Sorted array:", sorted_array);

# Test with empty array
let empty_array = [];
print("Empty array:", empty_array);
print("After merge sort:", merge_sort_wrapper(empty_array.copy()));

# Test with single element
let single_element = [42];
print("Single element:", single_element);
print("After merge sort:", merge_sort_wrapper(single_element.copy()));

# Test with negative numbers
let negative_numbers = [-3, -1, -7, -4, -2, -6, -5];
print("Negative numbers:", negative_numbers);
print("After merge sort:", merge_sort_wrapper(negative_numbers.copy()));

# Performance test with larger array
let large_array = [];
for (let i = 100; i >= 1; i--) {
    large_array.push(i);
}
print("Large array (first 10):", large_array.slice(0, 10));
let sorted_large = merge_sort_wrapper(large_array.copy());
print("Sorted large array (first 10):", sorted_large.slice(0, 10));
