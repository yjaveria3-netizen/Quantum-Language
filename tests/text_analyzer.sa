# Text Analyzer
# Analyze text for word count, readability, and statistics

def count_words(text):
    words = text.split()
    return len(words)

def count_characters(text, include_spaces=True):
    if include_spaces:
        return len(text)
    else:
        return len(text.replace(" ", ""))

def count_sentences(text):
    sentences = text.split('.')
    sentences = [s.strip() for s in sentences if s.strip()]
    return len(sentences)

def count_paragraphs(text):
    paragraphs = text.split('\n\n')
    paragraphs = [p.strip() for p in paragraphs if p.strip()]
    return len(paragraphs)

def find_most_common_words(text, top_n=10):
    words = text.lower().split()
    word_count = {}
    
    for word in words:
        # Remove punctuation
        clean_word = ''.join(c for c in word if c.isalnum())
        if clean_word:
            word_count[clean_word] = word_count.get(clean_word, 0) + 1
    
    # Sort by frequency
    sorted_words = sorted(word_count.items(), key=lambda x: x[1], reverse=True)
    return sorted_words[:top_n]

def calculate_reading_time(text, words_per_minute=200):
    word_count = count_words(text)
    minutes = word_count / words_per_minute
    return round(minutes, 1)

def analyze_text(text):
    print("Text Analysis Results")
    print("=" * 25)
    
    # Basic counts
    word_count = count_words(text)
    char_count = count_characters(text)
    char_no_spaces = count_characters(text, False)
    sentence_count = count_sentences(text)
    paragraph_count = count_paragraphs(text)
    
    print(f"Words: {word_count}")
    print(f"Characters (with spaces): {char_count}")
    print(f"Characters (no spaces): {char_no_spaces}")
    print(f"Sentences: {sentence_count}")
    print(f"Paragraphs: {paragraph_count}")
    
    # averages
    if sentence_count > 0:
        avg_words_per_sentence = word_count / sentence_count
        print(f"Average words per sentence: {avg_words_per_sentence:.1f}")
    
    if paragraph_count > 0:
        avg_words_per_paragraph = word_count / paragraph_count
        print(f"Average words per paragraph: {avg_words_per_paragraph:.1f}")
    
    # Reading time
    reading_time = calculate_reading_time(text)
    print(f"Estimated reading time: {reading_time} minutes")
    
    # Most common words
    print("\nMost Common Words:")
    common_words = find_most_common_words(text)
    for i, (word, count) in enumerate(common_words, 1):
        print(f"{i}. {word}: {count}")

def text_analyzer():
    print("Text Analyzer")
    print("=" * 15)
    
    while True:
        print("\nOptions:")
        print("1. Analyze text from input")
        print("2. Analyze text from file")
        print("3. Compare two texts")
        print("4. Exit")
        
        choice = input("Enter your choice (1-4): ")
        
        if choice == '1':
            print("Enter your text (press Enter twice to finish):")
            lines = []
            while True:
                line = input()
                if line == "" and len(lines) > 0 and lines[-1] == "":
                    break
                lines.append(line)
            
            text = '\n'.join(lines[:-1])  # Remove last empty line
            if text:
                analyze_text(text)
            else:
                print("No text entered")
        
        elif choice == '2':
            filename = input("Enter filename: ")
            try:
                with open(filename, 'r') as file:
                    text = file.read()
                analyze_text(text)
            except FileNotFoundError:
                print(f"File '{filename}' not found")
            except Exception as e:
                print(f"Error reading file: {e}")
        
        elif choice == '3':
            print("Enter first text (press Enter twice to finish):")
            lines1 = []
            while True:
                line = input()
                if line == "" and len(lines1) > 0 and lines1[-1] == "":
                    break
                lines1.append(line)
            text1 = '\n'.join(lines1[:-1])
            
            print("\nEnter second text (press Enter twice to finish):")
            lines2 = []
            while True:
                line = input()
                if line == "" and len(lines2) > 0 and lines2[-1] == "":
                    break
                lines2.append(line)
            text2 = '\n'.join(lines2[:-1])
            
            if text1 and text2:
                print("\nText Comparison:")
                print("-" * 20)
                
                words1 = count_words(text1)
                words2 = count_words(text2)
                
                print(f"Text 1 - Words: {words1}")
                print(f"Text 2 - Words: {words2}")
                print(f"Difference: {abs(words1 - words2)} words")
                
                time1 = calculate_reading_time(text1)
                time2 = calculate_reading_time(text2)
                print(f"Text 1 - Reading time: {time1} minutes")
                print(f"Text 2 - Reading time: {time2} minutes")
            else:
                print("Please enter both texts")
        
        elif choice == '4':
            print("Goodbye!")
            break
        
        else:
            print("Invalid choice. Please try again.")

# Run the text analyzer
text_analyzer()
