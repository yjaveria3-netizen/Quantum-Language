// ════════════════════════════════════════════════════════════
//  SECTION 6 — CAESAR CIPHER (ROT-N)
// ════════════════════════════════════════════════════════════

print("\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
print("  SECTION 6 — CAESAR CIPHER (ROT-N)")
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn caesar_encrypt(text, shift) {
    let result = ""
    let i = 0
    while i < len(text) {
        let c = ord(text[i])
        if c >= 65 and c <= 90 {
            result += chr((c - 65 + shift) % 26 + 65)
        } elif c >= 97 and c <= 122 {
            result += chr((c - 97 + shift) % 26 + 97)
        } else {
            result += text[i]
        }
        i += 1
    }
    return result
}

fn caesar_decrypt(text, shift) {
    return caesar_encrypt(text, 26 - (shift % 26))
}

let caesar_msg   = "Hello from Quantum Language"
let caesar_shift = 7

let caesar_enc = caesar_encrypt(caesar_msg, caesar_shift)
let caesar_dec = caesar_decrypt(caesar_enc, caesar_shift)

print("Shift     : " + str(caesar_shift))
print("Plaintext : " + caesar_msg)
print("Encrypted : " + caesar_enc)
print("Decrypted : " + caesar_dec)

// ROT13 is Caesar-13 — verify with builtin
let rot13_test = rot13(caesar_msg)
let rot13_back = rot13(rot13_test)
print("\nROT-13 (builtin):")
print("  Encoded : " + rot13_test)
print("  Decoded : " + rot13_back)


