// ════════════════════════════════════════════════════════════
//  SECTION 14 — SALTED PASSWORD HASHING
// ════════════════════════════════════════════════════════════

print("\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
print("  SECTION 14 — SALTED PASSWORD HASHING")
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn hash_password(password) {
    let salt   = secure_random_hex(16)
    let hash_val = sha256(salt + password)
    return salt + ":" + hash_val
}

fn verify_password(password, stored) {
    let parts  = stored.split(":")
    let salt   = parts[0]
    let stored_hash = parts[1]
    let attempt_hash = sha256(salt + password)
    return constant_time_eq(stored_hash, attempt_hash)
}

let user_password = "MySecretPassword123!"
let stored_hash   = hash_password(user_password)

print("Password    : " + user_password)
print("Stored hash : " + stored_hash)
print("")
print("Verify correct password : " + str(verify_password(user_password, stored_hash)))
print("Verify wrong password   : " + str(verify_password("WrongPassword", stored_hash)))

// Show that same password produces different hashes (salt randomness)
let hash1 = hash_password(user_password)
let hash2 = hash_password(user_password)
print("\nSame password, two different stored hashes (salts differ):")
print("  Hash 1: " + hash1)
print("  Hash 2: " + hash2)
print("  Equal? : " + str(constant_time_eq(hash1, hash2)))


