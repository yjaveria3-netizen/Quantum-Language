print("  SECTION 16 — CTF TOOLKIT")
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

// XOR brute-force single-byte key finder
// Given ciphertext encrypted with XOR key, find the key by checking
// which decryption produces the most readable ASCII text.

fn xor_single_byte(data, key_byte) {
    let result = ""
    let j = 0
    while j < len(data) {
        result += chr(ord(data[j]) ^ key_byte)
        j += 1
    }
    return result
}

fn score_english(text) {
    let common = "etaoinshrdlu ETAOINSHRDLU"
    let score  = 0
    let j = 0
    while j < len(text) {
        let c = ord(text[j])
        // printable ASCII bonus
        if c >= 32 and c <= 126 {
            score += 1
        }
        // common letter bonus
        let k = 0
        while k < len(common) {
            if text[j] == common[k] {
                score += 3
            }
            k += 1
        }
        j += 1
    }
    return score
}

fn xor_brute_single(ciphertext_hex) {
    let ct      = from_hex(ciphertext_hex)
    let best_key   = 0
    let best_score = -1
    let best_plain = ""
    let key = 0
    while key < 256 {
        let attempt = xor_single_byte(ct, key)
        let s       = score_english(attempt)
        if s > best_score {
            best_score = s
            best_key   = key
            best_plain = attempt
        }
        key += 1
    }
    return best_key
}

// Create a challenge: XOR encrypt a message with key 0x42
let ctf_msg    = "The flag is: QUANTUM{xor_is_easy_to_break}"
let ctf_key    = 0x42
let ctf_ct     = xor_single_byte(ctf_msg, ctf_key)
let ctf_ct_hex = to_hex(ctf_ct)

print("CTF Challenge:")
print("  Ciphertext (hex) : " + ctf_ct_hex)

let found_key = xor_brute_single(ctf_ct_hex)
let found_ct  = from_hex(ctf_ct_hex)
let decrypted_flag = xor_single_byte(found_ct, found_key)

print("  Brute-forced key : 0x" + to_hex(chr(found_key)))
print("  Recovered flag   : " + decrypted_flag)

// Frequency analysis hint
fn char_frequency(text) {
    let counts = {}
    let j = 0
    while j < len(text) {
        let c = text[j]
        if has(counts, c) {
            counts[c] = counts[c] + 1
        } else {
            counts[c] = 1
        }
        j += 1
    }
    return counts
}

print("\nBase64 decode a typical CTF encoded string:")
let ctf_b64 = "UVVBTVRVTXTJBGFZC2ljX2I2NF9jaGFsbGVuZ2V9"
let ctf_decoded = base64_decode(ctf_b64)
print("  Encoded  : " + ctf_b64)
print("  Decoded  : " + ctf_decoded)


