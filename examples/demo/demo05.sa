let test_strings = ["A", "Hello", "BlockAligned!", "Exactly16Bytes!!"]
let block_size   = 16
let ti = 0
while ti < len(test_strings) {
    let s       = test_strings[ti]
    let padded  = pkcs7_pad(s, block_size)
    let unpadded = pkcs7_unpad(padded)
    let pad_byte = ord(padded[len(padded) - 1])
    print("  \"" + s + "\" (len=" + str(len(s)) + ")")
    print("    → padded len=" + str(len(padded)) + "  pad_byte=0x" + to_hex(chr(pad_byte)))
    print("    → unpadded=\"" + unpadded + "\"")
    ti += 1
}


