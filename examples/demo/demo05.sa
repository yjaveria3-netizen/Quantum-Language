fn check_card(number, label) {
    let valid = luhn_check(number)
    let status = "INVALID ✗"
    if valid {
        status = "VALID ✓"
    }
    print("  " + label + ": " + number + " → " + status)
}

// Known valid test card numbers (Luhn-valid, not real cards)
check_card("4532015112830366", "Visa test")
check_card("5425233430109903", "Mastercard test")
check_card("374251018720955",  "Amex test")
check_card("6011000990139424", "Discover test")
check_card("1234567890123456", "Random (invalid)")
check_card("0000000000000000", "All zeros (invalid)")

// Generate a Luhn-valid number from scratch
fn luhn_generate(prefix, total_len) {
    // Fill with random digits up to total_len - 1
    let number = prefix
    while len(number) < total_len - 1 {
        number += str(secure_random_int(0, 9))
    }
    // Compute check digit
    let sum_ = 0
    let alt  = true
    let idx  = len(number) - 1
    while idx >= 0 {
        let d = num(number[idx])
        if alt {
            d = d * 2
            if d > 9 { d = d - 9 }
        }
        sum_ += d
        alt  = !alt
        idx  -= 1
    }
    let check_digit = (10 - (sum_ % 10)) % 10
    return number + str(check_digit)
}

let generated = luhn_generate("4532", 16)
print("\nGenerated Luhn-valid number: " + generated)
print("Verification: " + str(luhn_check(generated)))


