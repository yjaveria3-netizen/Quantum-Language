fn rate_password(pw) {
    let e = entropy(pw)
    let rating = ""
    let advice = ""
    if e < 1.0 {
        rating = "TERRIBLE"
        advice = "Single character repeated"
    } elif e < 2.0 {
        rating = "VERY WEAK"
        advice = "Almost no variety"
    } elif e < 2.8 {
        rating = "WEAK"
        advice = "Add numbers, symbols, mixed case"
    } elif e < 3.5 {
        rating = "MEDIUM"
        advice = "Getting there — add more variety"
    } elif e < 4.0 {
        rating = "STRONG"
        advice = "Good password"
    } else {
        rating = "EXCELLENT"
        advice = "Cryptographically strong"
    }
    print("  [" + rating + "] entropy=" + str(e) + "  \"" + pw + "\"")
    print("          → " + advice)
}

let passwords = [
    "aaaaaaaaaa",
    "password",
    "Password1",
    "P@ssw0rd!",
    "correct-horse-battery-staple",
    "Tr0ub4dor&3",
    "xK9#mP2@qL5!nR8$"
]

let pi = 0
while pi < len(passwords) {
    rate_password(passwords[pi])
    pi += 1
}

