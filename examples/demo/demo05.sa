// Simulate a file integrity checker using SHA-256

fn compute_checksum(data) {
    return sha256(data)
}

fn verify_integrity(data, expected_checksum) {
    let actual = compute_checksum(data)
    return constant_time_eq(actual, expected_checksum)
}

let file_content  = "This is the content of an important config file.\nversion=1.1\nmode=secure\n"
let checksum      = compute_checksum(file_content)

print("File content     : " + file_content)
print("SHA-256 checksum : " + checksum)
print("Integrity OK     : " + str(verify_integrity(file_content, checksum)))

// Simulate tampering
let tampered_file = "This is the content of an important config file.\nversion=1.1\nmode=HACKED\n"
print("\nAfter tampering  :")
print("Tampered content : " + tampered_file)
print("Integrity OK     : " + str(verify_integrity(tampered_file, checksum)))

// HMAC-protected manifest (stronger than plain hash — prevents length extension attacks)
let manifest_key  = secure_random_hex(32)
let manifest_data = file_content
let manifest_mac  = hmac_sha256(manifest_key, manifest_data)

print("\nHMAC-protected manifest:")
print("MAC : " + manifest_mac)
print("Verify original : " + str(constant_time_eq(manifest_mac, hmac_sha256(manifest_key, manifest_data))))
print("Verify tampered : " + str(constant_time_eq(manifest_mac, hmac_sha256(manifest_key, tampered_file))))


