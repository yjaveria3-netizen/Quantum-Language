// Hex dump — print bytes with their offsets (useful for binary analysis)
fn hex_dump(data, label) {
    print("\nHex dump [" + label + "] (" + str(len(data)) + " bytes):")
    let row = ""
    let ascii_row = ""
    let j = 0
    while j < len(data) {
        let byte_val = ord(data[j])
        let h = to_hex(data[j])
        // pad single digit
        if len(h) < 2 {
            h = "0" + h
        }
        row += h + " "
        if byte_val >= 32 and byte_val <= 126 {
            ascii_row += data[j]
        } else {
            ascii_row += "."
        }
        if (j + 1) % 16 == 0 or j == len(data) - 1 {
            // pad last row
            let pad = (16 - ((j % 16) + 1)) % 16
            let k = 0
            while k < pad {
                row += "   "
                ascii_row += " "
                k += 1
            }
            print("  " + row + " | " + ascii_row)
            row = ""
            ascii_row = ""
        }
        j += 1
    }
}

hex_dump("Hello, Quantum!", "string literal")
hex_dump(ciphertext, "AES-128 ciphertext")


