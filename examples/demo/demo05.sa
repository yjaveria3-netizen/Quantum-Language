print("\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
print("  SECTION 15 — API TOKEN SYSTEM")
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

let server_secret = secure_random_hex(32)

fn generate_token(user_id, role) {
    let nonce   = secure_random_hex(8)
    let claims  = "uid=" + user_id + "&role=" + role + "&nonce=" + nonce
    let sig     = hmac_sha256(server_secret, claims)
    return base64_encode(claims) + "." + sig
}

fn verify_token(token) {
    let parts = token.split(".")
    if len(parts) < 2 {
        return false
    }
    let claims  = base64_decode(parts[0])
    let sig     = parts[1]
    let expected = hmac_sha256(server_secret, claims)
    return constant_time_eq(sig, expected)
}

fn decode_token(token) {
    let parts = token.split(".")
    return base64_decode(parts[0])
}

let admin_token = generate_token("1001", "admin")
let user_token  = generate_token("1002", "user")

print("Admin token : " + admin_token)
print("User token  : " + user_token)
print("")
print("Verify admin token  : " + str(verify_token(admin_token)))
print("Verify user token   : " + str(verify_token(user_token)))
print("")
print("Admin claims : " + decode_token(admin_token))
print("User claims  : " + decode_token(user_token))

// Tamper with the token
let tampered_token = base64_encode("uid=1002&role=admin&nonce=hacked") + "." + "fakesignaturexxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
print("\nTampered token verify: " + str(verify_token(tampered_token)))


